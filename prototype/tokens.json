{
  "meta": {
    "name": "TrailNote Design Tokens",
    "version": "1.0.0",
    "platform": "web-mobile-prototype"
  },
  "color": {
    "brand": {
      "primary": "#285443",
      "primaryStrong": "#17352C",
      "primarySoft": "#3D7A61"
    },
    "accent": {
      "lake": "#3A7CA5",
      "sand": "#C59D5F",
      "clay": "#9B6B4F"
    },
    "surface": {
      "canvas": "#F4F6F3",
      "panel": "#FFFFFF",
      "muted": "#EEF2EE",
      "tint": "rgba(40, 84, 67, 0.08)"
    },
    "text": {
      "primary": "#111714",
      "secondary": "#57615D",
      "tertiary": "#7C8782",
      "inverse": "#FFFFFF"
    },
    "feedback": {
      "success": "#2D8A57",
      "warning": "#C88519",
      "error": "#BE4D3F",
      "info": "#3A7CA5"
    },
    "border": {
      "subtle": "rgba(23, 53, 44, 0.08)",
      "strong": "rgba(23, 53, 44, 0.16)"
    },
    "overlay": {
      "scrim": "rgba(11, 17, 14, 0.52)",
      "glass": "rgba(255, 255, 255, 0.78)"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "\"Cormorant Garamond\", serif",
      "body": "\"Noto Sans SC\", sans-serif"
    },
    "size": {
      "display": 32,
      "h1": 28,
      "h2": 24,
      "h3": 20,
      "title": 18,
      "body": 16,
      "bodySmall": 14,
      "caption": 12
    },
    "lineHeight": {
      "display": 40,
      "h1": 34,
      "h2": 30,
      "h3": 26,
      "title": 24,
      "body": 24,
      "bodySmall": 20,
      "caption": 16
    },
    "weight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "space": {
    "4": 4,
    "8": 8,
    "10": 10,
    "12": 12,
    "14": 14,
    "16": 16,
    "18": 18,
    "20": 20,
    "24": 24,
    "32": 32
  },
  "radius": {
    "xs": 10,
    "sm": 14,
    "md": 18,
    "lg": 24,
    "xl": 28,
    "pill": 999
  },
  "shadow": {
    "card": "0 18px 45px rgba(17, 23, 20, 0.15)",
    "soft": "0 10px 24px rgba(17, 23, 20, 0.05)",
    "float": "0 24px 80px rgba(8, 12, 10, 0.26)"
  },
  "motion": {
    "duration": {
      "press": "110ms",
      "micro": "160ms",
      "page": "220ms",
      "sheet": "260ms",
      "success": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.22, 1, 0.36, 1)",
      "emphasized": "cubic-bezier(0.2, 0.8, 0.2, 1)"
    }
  },
  "size": {
    "tapTargetMin": 44,
    "buttonPrimaryHeight": 52,
    "buttonSecondaryHeight": 44,
    "chipHeight": 32,
    "bottomNavHeight": 84,
    "fieldPaddingY": 14,
    "fieldPaddingX": 16,
    "pagePaddingX": 20
  },
  "component": {
    "buttonPrimary": {
      "background": "{color.brand.primary}",
      "text": "{color.text.inverse}",
      "height": "{size.buttonPrimaryHeight}",
      "radius": "{radius.md}"
    },
    "inputField": {
      "background": "{color.surface.panel}",
      "border": "{color.border.subtle}",
      "paddingY": "{size.fieldPaddingY}",
      "paddingX": "{size.fieldPaddingX}",
      "radius": "{radius.md}"
    },
    "card": {
      "background": "{color.surface.panel}",
      "border": "{color.border.subtle}",
      "radius": "{radius.lg}",
      "shadow": "{shadow.soft}"
    }
  }
}
